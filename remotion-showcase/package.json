{
  "name": "gross-ict-showcase",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion-rendered showcase video for Gross ICT homepage",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render Showcase ../assets/showcase.mp4 --concurrency=4",
    "render:poster": "remotion still Showcase ../assets/showcase-poster.jpg --frame=30 --image-format=jpeg --jpeg-quality=85"
  },
  "dependencies": {
    "@remotion/cli": "4.0.350",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.350"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/web": "0.0.196",
    "typescript": "5.7.3"
  }
}
